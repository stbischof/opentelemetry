-tester: biz.aQute.tester.junit-platform
-runee: JavaSE-21
-runfw: org.apache.felix.framework
-runstartlevel: order=sortbynameversion, begin=-1

-resolve.effective: active

-runrequires: \
	bnd.identity;id='${project.artifactId}-tests',\
	bnd.identity;id='${project.artifactId}'

-runbundles: \
	assertj-core;version='[3.24.2,3.24.3)',\
	junit-jupiter-api;version='[5.10.2,5.10.3)',\
	junit-jupiter-engine;version='[5.10.2,5.10.3)',\
	junit-jupiter-params;version='[5.10.2,5.10.3)',\
	junit-platform-commons;version='[1.10.2,1.10.3)',\
	junit-platform-engine;version='[1.10.2,1.10.3)',\
	junit-platform-launcher;version='[1.10.2,1.10.3)',\
	net.bytebuddy.byte-buddy;version='[1.12.21,1.12.22)',\
	org.apache.aries.spifly.dynamic.bundle;version='[1.3.7,1.3.8)',\
	org.apache.felix.configadmin;version='[1.9.26,1.9.27)',\
	org.apache.felix.scr;version='[2.2.14,2.2.15)',\
	org.eclipse.osgi-technology.opentelemetry.core.commons;version='[0.1.0,0.1.1)',\
	org.eclipse.osgi-technology.opentelemetry.core.sender.http;version='[0.1.0,0.1.1)',\
	org.eclipse.osgi-technology.opentelemetry.core.sender.http-tests;version='[0.1.0,0.1.1)',\
	org.eclipse.osgi-technology.opentelemetry.repack;version='[0.1.0,0.1.1)',\
	org.objectweb.asm;version='[9.9.0,9.9.1)',\
	org.objectweb.asm.commons;version='[9.9.0,9.9.1)',\
	org.objectweb.asm.tree;version='[9.9.0,9.9.1)',\
	org.objectweb.asm.tree.analysis;version='[9.9.0,9.9.1)',\
	org.objectweb.asm.util;version='[9.9.0,9.9.1)',\
	org.opentest4j;version='[1.3.0,1.3.1)',\
	org.osgi.service.component;version='[1.5.1,1.5.2)',\
	org.osgi.test.common;version='[1.3.0,1.3.1)',\
	org.osgi.test.junit5;version='[1.3.0,1.3.1)',\
	org.osgi.test.junit5.cm;version='[1.3.0,1.3.1)',\
	org.osgi.util.function;version='[1.2.0,1.2.1)',\
	org.osgi.util.promise;version='[1.3.0,1.3.1)'
