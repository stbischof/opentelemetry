          "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [{ "expr": "sum(rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_INTERNAL\", http_route=\"$http_route\"}[5m]))", "legendFormat": "rate", "refId": "A" }]
        },
        {
          "type": "stat",
          "title": "Avg Duration",
          "id": 203,
          "gridPos": { "h": 4, "w": 4, "x": 8, "y": 101 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "orange", "value": null }] }, "unit": "s" } },
