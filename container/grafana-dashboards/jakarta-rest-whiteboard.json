          "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [{ "expr": "histogram_quantile(0.99, sum by (le) (rate(traces_spanmetrics_latency_bucket{span_kind=\"SPAN_KIND_INTERNAL\", http_route=\"$http_route\"}[5m])))", "legendFormat": "p99", "refId": "A" }]
