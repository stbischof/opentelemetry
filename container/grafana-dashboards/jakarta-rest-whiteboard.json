          },
          "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
          "targets": [{
            "expr": "sum by (http_method) (rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_INTERNAL\", http_route=\"$http_route\"}[5m]))",
            "legendFormat": "{{http_method}}",
            "refId": "A"
          }]
        },
        {
          "type": "timeseries",
          "title": "Duration Percentiles — $http_route",
          "id": 211,
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 105 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": true }, "unit": "s" } },
          "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
          "targets": [
