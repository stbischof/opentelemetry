          "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [{ "expr": "sum(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_INTERNAL\", http_route=\"$http_route\"})", "legendFormat": "calls", "refId": "A" }]
