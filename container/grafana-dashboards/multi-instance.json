        ]
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "count by (job, osgi_framework_version) (osgi_bundle_count{job=~\"$instance\"})",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true
            },
            "renameByName": {
              "job_label": "Instance",
              "osgi_framework_version": "Framework Version"
