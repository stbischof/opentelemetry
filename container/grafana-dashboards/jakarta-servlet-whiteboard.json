{
  "uid": "jakarta-servlet-whiteboard",
  "title": "Jakarta Servlet Whiteboard",
  "description": "OSGi HTTP Whiteboard introspection: servlet contexts, servlets, filters, listeners, resources per context",
  "tags": ["osgi", "opentelemetry", "servlet", "whiteboard"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(osgi_http_whiteboard_contexts, job)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "sort": 1
      },
      {
        "name": "context_name",
        "label": "Servlet Context",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(osgi_http_whiteboard_servlets{job=~\"$instance\"}, context_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 1
    },
    {
      "type": "stat",
      "title": "Servlet Contexts",
      "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "expr": "sum(osgi_http_whiteboard_contexts{job=~\"$instance\"})",
        "legendFormat": "contexts",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Total Servlets",
